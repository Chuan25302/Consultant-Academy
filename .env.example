GOOGLE_API_KEY=AIzaSy_YOUR_GEMINI_KEY

# Service account JSON key file (share Drive folders with this SA's email)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

CALENDAR_FILE_ID=1xxxxxxxxxxxxxxx
FOLDER_EMAIL_ARCHIVES=1xxxxxxxxxxxxxxx
FOLDER_KNOWLEDGE_BASE=1xxxxxxxxxxxxxxx
FOLDER_PROGRAM_MGMT=1xxxxxxxxxxxxxxx

# Optional: Slack incoming webhook for failure alerts
SLACK_WEBHOOK_URL=

# ─── Model selection ───────────────────────────────────────────────
# Default model used by every agent if no per-agent override set.
GEMINI_MODEL=gemini-2.0-flash

# Per-agent overrides. Pricing per 1M tokens (in/out):
#   gemini-2.0-flash      $0.075 / $0.30      ← cheap workhorse (recap, translator)
#   gemini-2.5-flash-lite $0.10  / $0.40
#   gemini-2.5-flash      $0.30  / $2.50      ← good reasoning (research, industry)
#   gemini-2.5-pro        $1.25  / $10.00     ← best quality (expert/factcheck/editor/sustainability)
#
# ─── Recommended config: ~2.5 บาท/วัน Mon-Fri, ~0.04 บาท Sat ───────
#   Pro 2.5 ที่ตำแหน่ง critical:
#     EXPERT (core), FACTCHECKER (no-halluc), EDITOR (final QA),
#     SUSTAINABILITY (carbon math accuracy)
#   Flash 2.5 ที่ INDUSTRY / RESEARCH / TRANSLATOR (mid-tier reasoning)
#   Flash 2.0 ที่ RECAP (Saturday — งานเบา summary)
#
#  Budget Mon-Fri: ~$0.07 (~2.5 บาท/วัน) — fits user's 3 บาท ceiling
#  Saturday RECAP only: ~$0.001 (~0.04 บาท)
#  Per month: ~$1.50 (~50 บาท)

GEMINI_MODEL_RESEARCH=gemini-2.5-flash
GEMINI_MODEL_EXPERT=gemini-2.5-pro
GEMINI_MODEL_INDUSTRY=gemini-2.5-flash
GEMINI_MODEL_FACTCHECKER=gemini-2.5-pro
GEMINI_MODEL_TRANSLATOR=gemini-2.5-flash
GEMINI_MODEL_EDITOR=gemini-2.5-pro
GEMINI_MODEL_SUSTAINABILITY=gemini-2.5-pro
GEMINI_MODEL_RECAP=gemini-2.0-flash
