GOOGLE_API_KEY=AIzaSy_YOUR_GEMINI_KEY

# Service account JSON key file (share Drive folders with this SA's email)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

CALENDAR_FILE_ID=1xxxxxxxxxxxxxxx
FOLDER_EMAIL_ARCHIVES=1xxxxxxxxxxxxxxx
FOLDER_KNOWLEDGE_BASE=1xxxxxxxxxxxxxxx
FOLDER_PROGRAM_MGMT=1xxxxxxxxxxxxxxx

# Optional: Slack incoming webhook for failure alerts
SLACK_WEBHOOK_URL=

# ─── Model selection ───────────────────────────────────────────────
# Default model used by every agent if no per-agent override set.
GEMINI_MODEL=gemini-2.0-flash

# Per-agent overrides (uncomment to use). Pricing per 1M tokens (in/out):
#   gemini-2.0-flash      $0.075 / $0.30      ← default, fast, cheap
#   gemini-2.0-flash-lite $0.075 / $0.30      ← cheapest, smaller context
#   gemini-2.5-flash-lite $0.10  / $0.40      ← good middle ground
#   gemini-2.5-flash      $0.30  / $2.50      ← much better quality
#   gemini-2.5-pro        $1.25  / $10.00     ← best quality, expensive
#
# Recommended setup: Pro for the core "expert" content, Flash for the rest.
# Total monthly cost stays well under $1 for daily Mon–Fri runs.
#
# GEMINI_MODEL_RESEARCH=gemini-2.0-flash
# GEMINI_MODEL_EXPERT=gemini-2.5-pro
# GEMINI_MODEL_INDUSTRY=gemini-2.0-flash
# GEMINI_MODEL_TRANSLATOR=gemini-2.0-flash
# GEMINI_MODEL_RECAP=gemini-2.0-flash
